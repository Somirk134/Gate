{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Gate",
    "version": "0.9.0",
    "identifier": "dev.gateproject.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Gate",
                "width": 1440,
                "height": 900,
                "minWidth": 1100,
                "minHeight": 720,
                "center": true,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        },
        "trayIcon": {
            "iconPath": "icons/32x32.png",
            "iconAsTemplate": false
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico"
        ],
        "windows": {
            "wix": null,
            "nsis": {
                "displayLanguageSelector": false,
                "installerIcon": "icons/icon.ico",
                "installMode": "perMachine"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15"
        },
        "linux": {
            "deb": {
                "depends": []
            }
        }
    }
}
