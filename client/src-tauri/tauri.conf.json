{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Gate",
    "version": "0.9.0",
    "identifier": "dev.gateproject.gate",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Gate",
                "width": 1440,
                "height": 900,
                "minWidth": 1100,
                "minHeight": 720,
                "center": true,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        },
        "trayIcon": {
            "iconPath": "icons/32x32.png",
            "iconAsTemplate": false
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis", "dmg", "appimage", "deb"],
        "createUpdaterArtifacts": false,
        "publisher": "Gate Contributors",
        "homepage": "https://github.com/Somirk134/Gate",
        "category": "DeveloperTool",
        "shortDescription": "Gate desktop tunnel client",
        "longDescription": "Gate is a self-hosted desktop tunnel client for TCP, HTTP, and HTTPS access.",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico"
        ],
        "windows": {
            "allowDowngrades": false,
            "webviewInstallMode": {
                "type": "downloadBootstrapper",
                "silent": true
            },
            "nsis": {
                "displayLanguageSelector": true,
                "installerIcon": "icons/icon.ico",
                "uninstallerIcon": "icons/icon.ico",
                "installMode": "currentUser",
                "languages": ["SimpChinese", "English"],
                "startMenuFolder": "Gate"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15",
            "dmg": {
                "windowSize": {
                    "width": 660,
                    "height": 400
                },
                "appPosition": {
                    "x": 180,
                    "y": 170
                },
                "applicationFolderPosition": {
                    "x": 480,
                    "y": 170
                }
            }
        },
        "linux": {
            "appimage": {
                "bundleMediaFramework": false
            },
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libgtk-3-0",
                    "libayatana-appindicator3-1",
                    "librsvg2-2"
                ]
            }
        }
    }
}
