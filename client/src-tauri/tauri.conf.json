{
    "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "Gate",
    "version": "0.1.0",
    "identifier": "com.gate.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Gate",
                "width": 1200,
                "height": 800,
                "minWidth": 900,
                "minHeight": 600,
                "center": true,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        },
        "trayIcon": {
            "iconPath": "icons/32x32.png",
            "iconAsTemplate": true
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png"
        ],
        "windows": {
            "wix": null,
            "nsis": null
        },
        "macOS": {
            "minimumSystemVersion": "10.15"
        },
        "linux": {
            "deb": {
                "depends": []
            }
        }
    },
    "plugins": {
        "updater": {
            "endpoints": ["https://releases.gate-project.dev/{{target}}/{{current_version}}"],
            "pubkey": ""
        }
    }
}
